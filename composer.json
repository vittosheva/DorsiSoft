{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": [
        "laravel",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "azgasim/filament-unsaved-changes-modal": "^1.0.1",
        "balismatz/filament-prevent-outdated-record-update": "^5.0.1",
        "barryvdh/laravel-dompdf": "^3.1.2",
        "coolsam/modules": "^5.1",
        "craft-forge/filament-language-switcher": "^1.2.1",
        "filament/filament": "^5.6.2",
        "jeffersongoncalves/filament-qrcode-field": "^3.0.4",
        "laravel-lang/common": "^6.8.0",
        "laravel/framework": "^13.7",
        "laravel/sanctum": "^4.3.1",
        "laravel/tinker": "^3.0.2",
        "malzariey/filament-daterangepicker-filter": "^5.0.1",
        "marcelweidum/filament-expiration-notice": "^1.0.16",
        "mayaram/laravel-ocr": "^1.3.0",
        "nunomaduro/essentials": "^1.2",
        "picqer/php-barcode-generator": "^3.2.4",
        "spatie/browsershot": "^5.3.0",
        "spatie/laravel-pdf": "^2.8",
        "spatie/laravel-permission": "^7.4.1",
        "tapp/filament-timezone-field": "^3.1.0",
        "tonegabes/filament-better-options": "^1.4.0",
        "tonegabes/filament-phosphor-icons": "^1.3.1",
        "wildside/userstamps": "^4.0.0",
        "yousefaman/filament-modal-repeater": "^1.1.0",
        "zvizvi/user-fields": "^0.0.4"
    },
    "require-dev": {
        "fakerphp/faker": "^1.24.1",
        "filament/blueprint": "^2.1.2",
        "fruitcake/laravel-debugbar": "^4.2",
        "laravel/boost": "^2.4.6",
        "laravel/pail": "^1.2.6",
        "laravel/pao": "^1.0.6",
        "laravel/pint": "^1.29.1",
        "laraveldaily/filacheck": "^1.2.0",
        "mockery/mockery": "^1.6.12",
        "nunomaduro/collision": "^8.9.4",
        "pestphp/pest": "^4.7.0",
        "pestphp/pest-plugin-laravel": "^4.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install --ignore-scripts",
            "npm run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1 --timeout=0\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "optimize": [
            "@php artisan config:cache --ansi",
            "@php artisan route:cache --ansi",
            "@php artisan event:cache --ansi",
            "@php artisan view:cache --ansi"
        ],
        "optimize:clear": [
            "@php artisan optimize:clear --ansi"
        ],
        "test": [
            "@php artisan config:clear --ansi @no_additional_args",
            "@php artisan test"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade",
            "@php artisan filament:assets"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@php artisan boost:update --ansi",
            "@php artisan lang:update"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        },
        "merge-plugin": {
            "include": [
                "Modules/*/composer.json"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "wikimedia/composer-merge-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "repositories": [
        {
            "name": "filament",
            "type": "composer",
            "url": "https://packages.filamentphp.com/composer"
        }
    ]
}
